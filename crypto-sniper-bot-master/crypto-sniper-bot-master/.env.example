# ─────────────────────────────────────────────────────────
#  Crypto Sniper Bot — Environment Variables
# ─────────────────────────────────────────────────────────

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here

# ── Admin Panel ───────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_SECRET_KEY=generate_with_python_secrets_token_hex_32

# Optional: enable TOTP 2FA for admin panel
# Generate with: python -c "import pyotp; print(pyotp.random_base32())"
# Then scan QR in Google Authenticator
ADMIN_TOTP_SECRET=

# ── Payments (CryptoBot) ──────────────────────────────────
# Get token from @CryptoBot in Telegram → Create App
CRYPTOBOT_TOKEN=

# ── Trading encryption ────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Blockchain RPCs (optional, uses public nodes by default) ──
SOLANA_RPC=https://api.mainnet-beta.solana.com
BSC_RPC=https://bsc-dataseed.binance.org

# ── Scanner intervals (seconds) ──────────────────────────
SCAN_INTERVAL_SEC=60
GECKO_INTERVAL_SEC=45
PUMPFUN_INTERVAL_SEC=30

# ── Web server port ───────────────────────────────────────
PORT=5000
